# Django core
DJANGO_SECRET_KEY=replace-with-a-very-long-random-secret-key-at-least-50-characters-123456789
DJANGO_DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,your-backend.onrender.com

# Render provides this automatically for managed Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=True

# Frontend integration
FRONTEND_BASE_URL=https://feathure.d374ersqg5p6cr.amplifyapp.com
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://feathure.d374ersqg5p6cr.amplifyapp.com
CSRF_TRUSTED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://feathure.d374ersqg5p6cr.amplifyapp.com

# Optional explicit database params (use when DATABASE_URL is not provided)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=require

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=example_user
EMAIL_HOST_PASSWORD=example_password
DEFAULT_FROM_EMAIL=no-reply@example.com

# JWT and logging
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
DJANGO_LOG_LEVEL=INFO

# Production security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional Supabase sync
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
